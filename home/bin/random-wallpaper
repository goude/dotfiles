#!/usr/bin/env bash
# Random wallpaper setter using swww

# Configuration
WALLPAPER_DIR="$HOME/wallpapers"

# Verify the folder exists
if [ ! -d "$WALLPAPER_DIR" ]; then
  echo "Error: $WALLPAPER_DIR does not exist."
  exit 1
fi

# Pick a random image from anywhere under the wallpaper dir (recursive, so all
# the source/author subfolders are included). Hidden dirs (.claude, .remember)
# are pruned; the extension filter keeps non-images like provenance.json out.
file=$(find "$WALLPAPER_DIR" -type d -name '.*' -prune -o -type f \
  \( -iname '*.gif' -o -iname '*.png' -o -iname '*.jpg' \
     -o -iname '*.jpeg' -o -iname '*.webp' \) -print 2>/dev/null | shuf -n 1)

if [ -z "$file" ]; then
  echo "No image files found in $WALLPAPER_DIR."
  exit 1
fi

echo "Setting wallpaper: $file"
notify-send "Setting wallpaper: $file"

# Record the choice so wallpaper-init restores it on the next session start.
swww img "$file" && printf '%s\n' "$file" >"$HOME/.cache/wallpaper-last"
