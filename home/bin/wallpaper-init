#!/usr/bin/env bash
# wallpaper-init — start swww and set a wallpaper at labwc session start.
#
# The labwc autostart used to launch only `swww-daemon`, which leaves the
# screen on swww's default (black) until something calls `swww img`. This
# starts the daemon (if needed), waits until it is actually ready, then
# restores the last-used wallpaper — or picks a random one from ~/wallpapers
# on first run — and records the choice so manual changes persist across boots.
set -u

BIN="$HOME/bin"
WALLPAPER_DIR="$HOME/wallpapers"
LAST_FILE="$HOME/.cache/wallpaper-last"

# Start the daemon if it isn't already up, then wait (≤5s) until it answers.
if ! "$BIN/swww" query >/dev/null 2>&1; then
  "$BIN/swww-daemon" >/dev/null 2>&1 &
  for _ in $(seq 1 50); do
    "$BIN/swww" query >/dev/null 2>&1 && break
    sleep 0.1
  done
fi

# Restore the last wallpaper if it still exists; otherwise pick a random one.
file=""
if [ -f "$LAST_FILE" ]; then
  read -r last < "$LAST_FILE" || true
  [ -n "${last:-}" ] && [ -f "$last" ] && file="$last"
fi
if [ -z "$file" ]; then
  file=$(find "$WALLPAPER_DIR" -maxdepth 1 -type f | shuf -n 1)
fi

[ -n "$file" ] || { echo "wallpaper-init: no wallpaper found in $WALLPAPER_DIR" >&2; exit 0; }

"$BIN/swww" img "$file" && printf '%s\n' "$file" >"$LAST_FILE"
