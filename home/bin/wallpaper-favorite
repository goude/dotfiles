#!/usr/bin/env bash
# Mark the currently-set wallpaper as a favorite (its full path, one per line).
set -u

WALLPAPER_DIR="$HOME/wallpapers"
LAST_FILE="$HOME/.cache/wallpaper-last"
FAV_FILE="$WALLPAPER_DIR/favorites.txt"

if [ ! -f "$LAST_FILE" ]; then
  notify-send "No current wallpaper recorded"
  exit 1
fi

read -r file <"$LAST_FILE"
if [ -z "$file" ] || [ ! -f "$file" ]; then
  notify-send "Current wallpaper not found: $file"
  exit 1
fi

if grep -qxF "$file" "$FAV_FILE" 2>/dev/null; then
  notify-send "Already a favorite: $(basename "$file")"
  exit 0
fi

printf '%s\n' "$file" >>"$FAV_FILE"
notify-send "Favorited: $(basename "$file")"
