// Rich local scheme — selected by conf.d/zellij.fish only on a local kitty or
// ghostty terminal on Linux, where the Kitty keyboard protocol makes
// Ctrl+Super and Ctrl+Alt distinguishable. Every other context (macOS, Windows,
// SSH, browser, plain tty) falls back to the Ctrl-a prefix in config-portable.kdl.
//
// Additive over zellij's defaults: only the deltas below are declared.
//   - Ctrl+letter mode chords are freed (pass through to the shell/TUIs).
//   - plain Alt is freed in normal mode (fish/readline word-jumps).
//   - Ctrl+Super switches modes; Ctrl+Alt drives prefix-free nav (normal+locked).
//   - Ctrl+b → tmux mode and all default mode internals are inherited as-is.
keybinds {
    // Free the default Ctrl+letter mode switches for apps (Ctrl+b → tmux stays).
    unbind "Ctrl p" "Ctrl t" "Ctrl n" "Ctrl s" "Ctrl o" "Ctrl h" "Ctrl g" "Ctrl q"

    // Free plain Alt in normal mode; zellij nav lives on Ctrl+Alt instead.
    normal {
        unbind "Alt f" "Alt n" "Alt i" "Alt o" "Alt h" "Alt l" "Alt j" "Alt k" "Alt Left" "Alt Right" "Alt Up" "Alt Down" "Alt =" "Alt +" "Alt -" "Alt [" "Alt ]" "Alt p" "Alt Shift p"
    }

    // Ctrl+Super enters each mode (exit with Esc/Enter, or jump between modes).
    shared_except "locked" {
        bind "Ctrl Super p" { SwitchToMode "Pane"; }
        bind "Ctrl Super t" { SwitchToMode "Tab"; }
        bind "Ctrl Super n" { SwitchToMode "Resize"; }
        bind "Ctrl Super s" { SwitchToMode "Scroll"; }
        bind "Ctrl Super o" { SwitchToMode "Session"; }
        bind "Ctrl Super h" { SwitchToMode "Move"; }
        bind "Ctrl Super g" { SwitchToMode "Locked"; }
        bind "Ctrl Super q" { Quit; }
    }
    locked {
        bind "Ctrl Super g" { SwitchToMode "Normal"; }
    }

    // Ctrl+Alt — prefix-free nav/actions, active in normal and locked.
    shared_among "normal" "locked" {
        bind "Ctrl Alt h" { MoveFocusOrTab "Left"; }
        bind "Ctrl Alt l" { MoveFocusOrTab "Right"; }
        bind "Ctrl Alt j" { MoveFocus "Down"; }
        bind "Ctrl Alt k" { MoveFocus "Up"; }
        bind "Ctrl Alt Left" "Ctrl Alt H" { GoToPreviousTab; }
        bind "Ctrl Alt Right" "Ctrl Alt L" { GoToNextTab; }
        bind "Ctrl Alt 1" { GoToTab 1; }
        bind "Ctrl Alt 2" { GoToTab 2; }
        bind "Ctrl Alt 3" { GoToTab 3; }
        bind "Ctrl Alt 4" { GoToTab 4; }
        bind "Ctrl Alt 5" { GoToTab 5; }
        bind "Ctrl Alt 6" { GoToTab 6; }
        bind "Ctrl Alt n" { NewTab; SwitchToMode "RenameTab"; TabNameInput 0; }
        bind "Ctrl Alt i" { MoveTab "Left"; }
        bind "Ctrl Alt o" { MoveTab "Right"; }
        bind "Ctrl Alt r" { UndoRenameTab; SwitchToMode "RenameTab"; TabNameInput 0; }
        bind "Ctrl Alt f" { ToggleFloatingPanes; }
        bind "Ctrl Alt x" { CloseFocus; }
        bind "Ctrl Alt z" { ToggleFocusFullscreen; }
        bind "Ctrl Alt q" { Detach; }
        bind "Ctrl Alt -" { NewPane "Down"; }
        bind "Ctrl Alt \\" { NewPane "Right"; }
        bind "Ctrl Alt [" { PreviousSwapLayout; }
        bind "Ctrl Alt ]" { NextSwapLayout; }
        bind "Ctrl Alt Down" "Ctrl Alt +" { Resize "Increase"; }
        bind "Ctrl Alt Up" "Ctrl Alt =" { Resize "Decrease"; }
    }

    // Rename starts empty instead of pre-filling the current name.
    tab {
        bind "r" { UndoRenameTab; SwitchToMode "RenameTab"; TabNameInput 0; }
    }
    pane {
        bind "c" { UndoRenamePane; SwitchToMode "RenamePane"; PaneNameInput 0; }
    }

    // tmux mode: modern | - splits alongside the default " and %.
    tmux {
        bind "-" { NewPane "Down"; SwitchToMode "Normal"; }
        bind "|" { NewPane "Right"; SwitchToMode "Normal"; }
    }
}

theme "gruvbox-dark-orange"
default_shell "fish"
pane_frames false
copy_command "cop"
show_startup_tips false
// No web client/server — keep zellij terminal-only.
web_server false
