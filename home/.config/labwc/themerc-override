window.active.shadow.size=56
window.inactive.shadow.size=40
window.active.shadow.color=#00000080
window.inactive.shadow.color=#00000060
window.active.shadow.offset.x=0
window.active.shadow.offset.y=6

window.active.label.bg:           flat solid #0a0a0a
window.active.label.text.color:   #ffffff
window.inactive.label.bg:         flat solid #2a2a2a
window.inactive.label.text.color: #aaaaaa

# Add a gloss-like horizontal highlight
window.active.title.bg:           gradient vertical
window.active.title.bg.color:     #111111
window.active.title.bg.colorTo:   #1e1e1e

window.inactive.title.bg:         gradient vertical
window.inactive.title.bg.color:   #1b1b1b
window.inactive.title.bg.colorTo: #2a2a2a

# Borders
border.width: 1
border.color: #000000

# ===== Root menu (right-click on desktop) — matched to the waybar bar =====
# labwc cannot read CSS variables, so these hex values MIRROR the shared
# palette in ~/.config/theme/colors.css. If you change a colour there,
# change it here too. (Menu FONT is set in rc.xml: <font place="MenuItem">.)
menu.items.bg.color:          #1a1b26
menu.items.text.color:        #c6d0f5
menu.items.active.bg.color:   #292a35
menu.items.active.text.color: #99d1db
menu.title.bg.color:          #0a0a0a
menu.title.text.color:        #ffffff
menu.separator.color:         #ffffff20
menu.separator.width:         1

