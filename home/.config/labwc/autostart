# Repair X cookie keyed to a stale hostname (raspberrypi -> laszlo) so
# Xwayland/X11 apps (e.g. rpi-imager) can authenticate. See script header.
~/bin/fix-xauth-hostname &
# Start swww AND set a wallpaper (the daemon alone leaves the screen black).
~/bin/wallpaper-init &
~/repos/Waybar/build/waybar &
(cd ~/repos/keyflow && just run &)
